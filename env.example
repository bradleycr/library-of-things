# Postgres connection string (required).
# Supabase: use the Session Pooler URI (port 6543).
# Local: postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=

# Steward dashboard password. Default: password123. Set something strong in production.
STEWARD_PASSWORD=

# SSL mode for the database connection.
# Leave unset for Supabase (encrypted, no CA check).
# Set to "strict" for self-hosted Postgres with a proper TLS cert.
# Set to "none" for local dev (no encryption).
# DB_SSL=

# Optional API smoke-test target.
# BASE_URL=http://127.0.0.1:3000

# Optional: scripts/set-vercel-env.mjs can push env vars to Vercel.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=library-of-things
# VERCEL_TEAM_SLUG=

# --- Apple Wallet (optional) ---
# When all signing vars below are set, members see "Add to Apple Wallet" after
# creating or viewing their card. See docs/WALLET.md for full setup.
# APPLE_WALLET_PASS_TYPE_ID=pass.com.yourorg.library
# APPLE_WALLET_TEAM_ID=XXXXXXXXXX
# APPLE_WALLET_ORGANIZATION_NAME=Your Library Name
# PEM values may use \n for newlines when stored on one line in Vercel.
# APPLE_WALLET_WWDR_PEM=
# APPLE_WALLET_SIGNER_CERT_PEM=
# APPLE_WALLET_SIGNER_KEY_PEM=
# APPLE_WALLET_SIGNER_KEY_PASSPHRASE=
# Or use file paths (handy locally) instead of *_PEM:
# APPLE_WALLET_WWDR_PATH=certs/wwdr.pem
# APPLE_WALLET_SIGNER_CERT_PATH=certs/signer.pem
# APPLE_WALLET_SIGNER_KEY_PATH=certs/signer.key
