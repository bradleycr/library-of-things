# Postgres connection string (required).
# Supabase: use the Session Pooler URI (port 6543).
# Local: postgresql://user:pass@localhost:5432/dbname
DATABASE_URL=

# Steward dashboard password. Default: password123. Set something strong in production.
STEWARD_PASSWORD=

# SSL mode for the database connection.
# Leave unset for Supabase (encrypted, no CA check).
# Set to "strict" for self-hosted Postgres with a proper TLS cert.
# Set to "none" for local dev (no encryption).
# DB_SSL=

# Optional API smoke-test target.
# BASE_URL=http://127.0.0.1:3000

# Optional: scripts/set-vercel-env.mjs can push env vars to Vercel.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=library-of-things
# VERCEL_TEAM_SLUG=
