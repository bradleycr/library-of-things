# Supabase Postgres connection string. For Vercel, use the Transaction pooler (port 6543).
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Steward area (dashboard, add-book). Default: password123. Set a strong password in production.
STEWARD_PASSWORD=

# Optional: for scripts/set-vercel-env.mjs to push DATABASE_URL + STEWARD_PASSWORD to Vercel.
# Create at https://vercel.com/account/tokens (do not commit .env.local).
VERCEL_TOKEN=

# SSL mode for database connection. Leave unset for Supabase (default: encrypted, no CA check).
# Set to "strict" for self-hosted Postgres with a proper TLS certificate.
# Set to "none" for local/unencrypted connections (dev only).
# DB_SSL=

# Optional for frontend SDK usage in future wallet/auth work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
